# Required: Bokio API bearer token
BOKIO_API_TOKEN=your_token_here

# Optional: default company ID so you don't need to pass it to every tool call
BOKIO_COMPANY_ID=ea9ee4dd-fae3-4aec-a7db-6fc9cc1f8135

# Optional: override the API base URL (defaults to https://api.bokio.se/v1)
# BOKIO_BASE_URL=https://api.bokio.se/v1
